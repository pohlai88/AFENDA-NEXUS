# Database — Neon Postgres
DATABASE_URL=postgresql://user:pass@host-pooler.neon.tech/dbname?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Runtime
NODE_ENV=development
PORT_API=3001
PORT_WEB=3000

# Auth (optional — dev mode trusts x-tenant-id/x-user-id headers when unset)
# JWT_SECRET=your-secret-at-least-16-chars
# JWKS_URL=https://your-auth-provider/.well-known/jwks.json
