# ============================================================================
# Afenda — Monorepo Environment Template
# Copy to .env and fill in values. NEVER commit the real .env file.
# SINGLE SOURCE OF TRUTH — all apps, scripts, and tools read from root .env.
# For app-specific overrides, use apps/<app>/.env.local (gitignored).
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
BASE_URL=http://localhost:3000
RLS_ENFORCED=false

# ── Dev Credentials ──────────────────────────────────────────────────────────
ENABLE_DEV_CREDENTIALS=true
DEV_AUTH_USERNAME=admin
DEV_AUTH_PASSWORD=admin

# ── Neon Database ────────────────────────────────────────────────────────────
# Pooled (PgBouncer) — runtime queries, serverless-safe
DATABASE_URL=postgresql://user:pass@host-pooler.neon.tech/dbname?sslmode=verify-full&channel_binding=require&sslnegotiation=direct
# Direct TCP — DDL, advisory locks, drizzle-kit, worker
DATABASE_URL_DIRECT=postgresql://user:pass@host.neon.tech/dbname?sslmode=verify-full&channel_binding=require&sslnegotiation=direct
# Read replica — report routes (balance sheet, income statement, etc.)
# DATABASE_URL_READONLY=postgresql://user:pass@host-readonly.neon.tech/dbname?sslmode=verify-full&channel_binding=require
# Search worker — falls back to DATABASE_URL if unset
# SEARCH_WORKER_DATABASE_URL=

# ── Neon Project (CLI / branching / CI) ──────────────────────────────────────
NEON_PROJECT_ID=
# NEON_API_KEY=                  # Required for CI preview branches

# ── Neon Auth ────────────────────────────────────────────────────────────────
# Required in production. Omit in dev to enable trusted-header fallback.
# Format: https://<endpoint>.neonauth.<region>.aws.neon.tech/<dbname>/auth
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=         # min 32 chars — run: openssl rand -base64 32
# NEXT_PUBLIC_NEON_AUTH_URL=     # Client-side auth URL (defaults to NEON_AUTH_BASE_URL)
# JWKS_URL=                      # JWKS endpoint for JWT validation
# NEON_JWT_SECRET=               # JWT signing secret

# ── OAuth Providers ──────────────────────────────────────────────────────────
# Managed via Neon Auth dashboard. Only needed if self-hosting auth.
# GITHUB_ID=
# GITHUB_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Cloudflare R2 Storage ────────────────────────────────────────────────────
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# ── Observability (Grafana OTEL + Sentry/GlitchTip) ─────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_SERVICE_NAME=
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# ── Next.js Public Variables ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Email (Resend) ───────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxx
# DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
# DEFAULT_FROM_NAME=YourApp

# ── Third-Party API Keys ────────────────────────────────────────────────────
# GITHUB_TOKEN=                  # GitHub PAT for API access
# OPENAI_API_KEY=                # AI features
# ARCJET_KEY=                    # Bot protection
# POSTHOG_KEY=                   # Server-side analytics
# NEXT_PUBLIC_POSTHOG_KEY=       # Client-side analytics

# ── Stripe ───────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_FREE=price_xxx
# STRIPE_PRICE_STARTER=price_xxx
# STRIPE_PRICE_PROFESSIONAL=price_xxx
# STRIPE_PRICE_ENTERPRISE=price_xxx

# ── BetterStack ──────────────────────────────────────────────────────────────
# BETTERSTACK_GLOBAL_API_KEY=
# BETTERSTACK_UPTIME_API_TOKEN=
# BETTERSTACK_TELEMETRY_API_TOKEN=

# ── Redis (optional — rate limiting at scale) ────────────────────────────────
# REDIS_URL=redis://default:password@host:port

# ── Deployment ───────────────────────────────────────────────────────────────
# VERCEL_TOKEN=
# RAILWAY_TOKEN=
# TURBO_TOKEN=                   # Turbo remote cache
# TURBO_TEAM=
# CRON_SECRET=                   # Cron job authentication

# ── Figma (design tokens / codegen) ──────────────────────────────────────────
# FIGMA_PERSONAL_ACCESS_TOKEN=
# FIGMA_TOKEN=
# FIGMA_FILE_KEY=

# ── Application-Specific ────────────────────────────────────────────────────
# DEMO_VENDOR_ID=
