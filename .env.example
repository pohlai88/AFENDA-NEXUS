# Database — Neon Postgres
# sslmode=verify-full stops pg-connection-string deprecation warning; Neon recommends it
DATABASE_URL=postgresql://user:pass@host-pooler.neon.tech/dbname?sslmode=verify-full&channel_binding=require&sslnegotiation=direct
DATABASE_URL_DIRECT=postgresql://user:pass@host.neon.tech/dbname?sslmode=verify-full&channel_binding=require&sslnegotiation=direct
# Optional: read replica for reporting/analytics
# DATABASE_URL_READONLY=postgresql://user:pass@host-readonly.neon.tech/dbname?sslmode=verify-full&channel_binding=require
# Optional: sslmode override (require | verify-full)
# DATABASE_SSL_MODE=verify-full

# Runtime
NODE_ENV=development
PORT_API=3001
PORT_WEB=3000

# ── Neon Project (for CLI / branching / CI) ─────────────────────────────
NEON_PROJECT_ID=dark-band-87285012
# NEON_API_KEY=                  # Neon API key — required for CI preview branches

# ── Neon Auth (managed Better Auth service) ─────────────────────────────
# Required in production. In dev mode, omitting NEON_AUTH_BASE_URL enables
# trusted-header fallback (x-tenant-id / x-user-id).
#
# Each Neon branch gets its own Auth URL. Format:
#   https://<endpoint-id>.neonauth.<region>.aws.neon.tech/<dbname>/auth
#
# Production:  https://ep-fancy-wildflower-a1o82bpk.neonauth.ap-southeast-1.aws.neon.tech/neondb/auth
# Dev branch:  https://ep-misty-shadow-a18zhi2u.neonauth.ap-southeast-1.aws.neon.tech/neondb/auth
NEON_AUTH_BASE_URL=              # branch-specific Auth URL (see above)
NEON_AUTH_COOKIE_SECRET=         # min 32 chars — run: openssl rand -base64 32
# NEXT_PUBLIC_NEON_AUTH_URL=     # public URL for client-side auth (defaults to NEON_AUTH_BASE_URL)
# JWKS_URL=                      # JWKS endpoint for JWT validation

# Social OAuth — configured via Neon Auth dashboard, NOT in code.
# Managed providers: Google, GitHub (enabled in Neon Console → Auth → Providers)
# OAuth config is cloned when creating a branch (see: branching authentication docs).

# Email (Resend) — required for password reset, email verification, org invitations
# RESEND_API_KEY=re_xxxx
# DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
# DEFAULT_FROM_NAME=YourApp

# Redis (optional — for secondary storage / rate limiting at scale)
# REDIS_URL=redis://default:password@host:port
