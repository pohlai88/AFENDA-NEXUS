{
  // ── Vitest (monorepo): single root config; root must have vitest in devDependencies so the extension can load it.
  "vitest.rootConfig": "vitest.config.ts",
  "vitest.maximumConfigs": 15,

  // ── Reduce IDE noise — hide test / build / coverage artifacts ──
  "files.exclude": {
    "**/.turbo": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.next": true,
    "**/playwright-report": true,
    "**/test-results": true
  },
  "search.exclude": {
    "**/__tests__": true,
    "**/*.test.*": true,
    "**/*.spec.*": true,
    "**/coverage": true,
    "**/.next": true,
    "**/dist": true,
    "**/.turbo": true,
    "**/playwright-report": true,
    "**/test-results": true,
    "**/pnpm-lock.yaml": true
  },

  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],

  // ── Suppress diagnostics noise for non-code files ──────────────
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "editor.unicodeHighlight.ambiguousCharacters": false
  },
  "[md]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "editor.unicodeHighlight.ambiguousCharacters": false
  },
  "prettier.configPath": ".prettierrc.json",
  "prettier.ignorePath": ".prettierignore",
  "terminal.integrated.env.windows": {
    "PYTHONIOENCODING": "utf-8",
    "LANG": "en_US.UTF-8"
  },
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "args": ["-NoExit", "-Command", "chcp 65001 | Out-Null"]
    }
  },
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "files.encoding": "utf8",

  // ── Tailwind CSS IntelliSense ──────────────────────────────────
  "tailwindCSS.experimental.configFile": {
    "apps/web/src/app/globals.css": "apps/web/src/**"
  },
  "tailwindCSS.classAttributes": ["class", "className", "ngClass", "tw"],
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["clsx\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
  ],
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript"
  },
  "tailwindCSS.emmetCompletions": true,
  "files.associations": {
    "*.css": "tailwindcss",
    "ARCHITECTURE_*.md": "markdown"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },

  // ── Markdown Link Validation ───────────────────────────────────
  // Disable markdown link validation to prevent false positives on anchor links
  "markdown.validate.enabled": false,
  "markdown.validate.fileLinks.enabled": false,
  "markdown.validate.fragmentLinks.enabled": false
}
