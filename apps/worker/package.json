{
  "name": "@afenda/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@afenda/core": "workspace:*",
    "@afenda/db": "workspace:*",
    "@afenda/finance": "workspace:*",
    "@afenda/platform": "workspace:*",
    "@afenda/storage": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "graphile-worker": "catalog:",
    "ioredis": "^5.9.3",
    "postgres": "catalog:",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@afenda/eslint-config": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
