# ─── E2E Test credentials ────────────────────────────────────────────────────
# These override the root .env for Playwright tests.
# The test user is seeded by globalSetup (idempotent — safe to re-run).
TEST_USER_EMAIL=e2e-user@afenda-test.local
TEST_USER_PASSWORD=E2eTestP@ss1!
TEST_USER_NAME=E2E Test User

# ─── Override for test mode ───────────────────────────────────────────────────
# Unset NEON_AUTH_BASE_URL so API uses dev-fallback auth (trusts x-tenant-id/x-user-id headers).
# This is set per-webServer in playwright.config.ts, but kept here for reference.
# NEON_AUTH_BASE_URL=
