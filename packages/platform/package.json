{
  "name": "@afenda/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "ARCHITECTURE.@afenda-platform.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@afenda/core": "workspace:*",
    "dotenv": "^17.3.1",
    "find-up": "^8.0.0",
    "pino": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@afenda/eslint-config": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "pino-pretty": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}