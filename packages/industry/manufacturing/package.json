{
  "name": "@afenda/industry-manufacturing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/public.ts",
  "types": "./src/public.ts",
  "exports": {
    ".": {
      "import": "./dist/public.js",
      "types": "./dist/public.d.ts",
      "default": "./src/public.ts"
    }
  },
  "files": [
    "dist",
    "ARCHITECTURE.@afenda-industry-manufacturing.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly",
