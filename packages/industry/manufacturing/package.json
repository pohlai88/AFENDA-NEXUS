    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@afenda/core": "workspace:*"
  },
  "devDependencies": {
    "@afenda/typescript-config": "workspace:*",
    "@afenda/eslint-config": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}