{
  "name": "@afenda/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "source": "./src/client.ts",
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    }
  },
  "files": [
    "dist",
    "ARCHITECTURE.@afenda-db.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:reset": "drizzle-kit migrate && pnpm db:seed",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "gate:schema": "node ../../tools/scripts/gate-schema-conventions.mjs",
    "gate:db": "node ../../tools/scripts/gate-db-module.mjs"
  },
  "dependencies": {
    "@neondatabase/api-client": "^2.6.0",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@afenda/eslint-config": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
